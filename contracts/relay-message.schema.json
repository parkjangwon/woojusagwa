{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "woojusagwa relay message",
  "type": "object",
  "required": [
    "version",
    "title",
    "body",
    "receivedAt"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "sourceApp": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "receivedAt": {
      "type": "integer"
    },
    "deviceName": {
      "type": "string"
    }
  }
}
